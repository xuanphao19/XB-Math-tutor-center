generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Role {
  student
  teacher
  admin
}

enum Status {
  active
  inactive
}

enum Subject {
  TOAN
  HOA
}

enum Level {
  MAT_GOC
  TRUNG_BINH
  KHA
}

enum Phase {
  HOI_SINH
  LAP_LO
  TANG_TOC
}

enum QuestionType {
  single
  multiple
  text
}

enum ExerciseType {
  TRAC_NGHIEM
  TU_LUAN
  THI_THU
}

enum ProgressType {
  lesson
  exercise
  flashcard
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

//////////////////////////////////////
// USER
//////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  fullName    String
  email       String?  @unique
  phone       String?
  role        Role     @default(student)
  status      Status   @default(active)

  classGrade  String?
  level       Level?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relations
  submissions Submission[]
  progresses  Progress[]
  threads     Thread[]
  comments    Comment[]
  flashcards  FlashcardProgress[]
}

//////////////////////////////////////
// PARENT
//////////////////////////////////////

model Parent {
  id            String   @id @default(uuid())
  fullName      String
  phone         String
  zaloId        String?
  receiveReport Boolean  @default(true)

  students      ParentStudent[]

  createdAt     DateTime @default(now())
}

model ParentStudent {
  parentId  String
  studentId String

  parent    Parent @relation(fields: [parentId], references: [id])
  student   User   @relation(fields: [studentId], references: [id])

  @@id([parentId, studentId])
}

//////////////////////////////////////
// COURSE
//////////////////////////////////////

model Course {
  id          String   @id @default(uuid())
  title       String
  description String?

  subject     Subject
  grade       Int

  price       Float    @default(0)
  isPublished Boolean  @default(false)

  createdAt   DateTime @default(now())

  lessons     Lesson[]
  exercises   Exercise[]
}

//////////////////////////////////////
// LESSON
//////////////////////////////////////

model Lesson {
  id          String   @id @default(uuid())
  courseId    String

  title       String
  description String?

  order       Int
  phase       Phase
  subject     Subject

  videoUrl    String?
  pdfUrl      String?
  duration    Int?

  isFree      Boolean  @default(false)

  createdAt   DateTime @default(now())

  course      Course   @relation(fields: [courseId], references: [id])
  flashcards  Flashcard[]
}

//////////////////////////////////////
// QUESTION (BANK)
//////////////////////////////////////

model Question {
  id          String   @id @default(uuid())
  content     String
  type        QuestionType

  subject     Subject
  difficulty  Int

  explanation String?

  createdAt   DateTime @default(now())

  options     Option[]
  exercises   ExerciseQuestion[]
}

model Option {
  id          String   @id @default(uuid())
  questionId  String

  content     String
  isCorrect   Boolean

  question    Question @relation(fields: [questionId], references: [id])
}

//////////////////////////////////////
// EXERCISE / QUIZ
//////////////////////////////////////

model Exercise {
  id          String   @id @default(uuid())

  title       String
  type        ExerciseType

  subject     Subject
  level       Level

  timeLimit   Int?
  isFree      Boolean  @default(false)

  createdAt   DateTime @default(now())

  questions   ExerciseQuestion[]
  submissions Submission[]
}

model ExerciseQuestion {
  exerciseId  String
  questionId  String

  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])

  @@id([exerciseId, questionId])
}

//////////////////////////////////////
// SUBMISSION (BÀI LÀM)
//////////////////////////////////////

model Submission {
  id          String   @id @default(uuid())

  studentId   String
  exerciseId  String

  score       Float

  createdAt   DateTime @default(now())

  student     User     @relation(fields: [studentId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])

  answers     Answer[]
}

model Answer {
  id            String   @id @default(uuid())
  submissionId  String
  questionId    String

  answer        String
  isCorrect     Boolean

  submission    Submission @relation(fields: [submissionId], references: [id])
}

//////////////////////////////////////
// FLASHCARD
//////////////////////////////////////

model Flashcard {
  id          String   @id @default(uuid())
  lessonId    String?

  front       String
  back        String

  subject     Subject
  difficulty  String

  createdAt   DateTime @default(now())

  lesson      Lesson?  @relation(fields: [lessonId], references: [id])
  progresses  FlashcardProgress[]
}

model FlashcardProgress {
  id              String   @id @default(uuid())

  studentId       String
  flashcardId     String

  level           Int      @default(1)
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime?

  student         User     @relation(fields: [studentId], references: [id])
  flashcard       Flashcard @relation(fields: [flashcardId], references: [id])
}

//////////////////////////////////////
// PROGRESS (UNIFIED)
//////////////////////////////////////

model Progress {
  id          String   @id @default(uuid())

  studentId   String
  type        ProgressType
  refId       String

  status      ProgressStatus

  score       Float?
  attempts    Int      @default(0)

  lastAttemptAt DateTime?
  completedAt   DateTime?

  student     User @relation(fields: [studentId], references: [id])
}

//////////////////////////////////////
// COMMUNITY
//////////////////////////////////////

model Thread {
  id          String   @id @default(uuid())

  title       String
  content     String

  authorId    String
  subject     Subject

  lessonId    String?

  tags        String[]
  isResolved  Boolean  @default(false)
  votes       Int      @default(0)

  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id          String   @id @default(uuid())

  threadId    String
  authorId    String

  content     String
  parentId    String?

  createdAt   DateTime @default(now())

  thread      Thread   @relation(fields: [threadId], references: [id])
  author      User     @relation(fields: [authorId], references: [id])
}